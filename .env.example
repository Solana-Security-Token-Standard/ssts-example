# Default cluster
CLUSTER=devnet

# All bash entrypoint scripts load `${ENV_FILE:-.env}` automatically.
# You can override per command, for example:
#   ENV_FILE=.env.devnet npm run issuer:setup

# Optional RPC/WS overrides (used by setup, deploy, and e2e scripts/tests)
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_WS_URL=wss://api.devnet.solana.com/

# Optional signer override
# SOLANA_KEYPAIR=./config/solana/id.json

# Optional token root override (primarily for direct scripts/issuer-setup.ts usage)
# TOKEN_ROOT=.

# Token metadata and mint config
TOKEN_NAME="SSTS Example"
TOKEN_SYMBOL=SSTS
# Optional. Empty string is valid when no off-chain metadata URI is used.
TOKEN_URI=
TOKEN_DECIMALS=6

# Optional existing mint pubkey. If empty, a new mint is created.
# EXISTING_MINT=

# Initial mint amount in base units (u64). Set 0 to skip initial mint.
INITIAL_MINT_AMOUNT=0

# Owner pubkey for the initial minted ATA. Defaults to payer.
# INITIAL_RECIPIENT_OWNER=

# Auto-whitelist the initial recipient ATA (1/0, true/false).
AUTO_WHITELIST_INITIAL_RECIPIENT=1

# Comma-separated token account pubkeys to whitelist on setup.
# INITIAL_WHITELIST_TOKEN_ACCOUNTS=

# Devnet/localnet funding behavior
AUTO_AIRDROP=1
MIN_PAYER_BALANCE_SOL=0.5
AIRDROP_SOL=1

# Optional output artifact path
# ISSUER_STATE_PATH=./config/issuer-state-devnet.json

# --------------------------------------
# Testing overrides (unit/e2e)
# --------------------------------------

# Unit script: run Rust verifier unit tests (1) or skip them (0).
# RUN_RUST_TESTS=1

# Optional custom test directories.
# UNIT_TEST_TARGET=tests
# E2E_TEST_TARGET=tests/e2e

# E2E RPC retry/confirmation tuning (tests/e2e/helpers.ts)
# RPC_MAX_ATTEMPTS=8
# RPC_BASE_DELAY_MS=350
# RPC_MAX_DELAY_MS=5000
# RPC_CONFIRM_TIMEOUT_MS=90000
# RPC_CONFIRM_POLL_MS=700
# TX_MAX_ATTEMPTS=3
